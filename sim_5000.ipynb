    "def compute_step_function_area(step_points, num_districts):\n",
    "    # Ensure sorted by vote share\n",
    "    points = sorted(step_points, key=lambda x: x[0])\n",
    "    \n",
    "    # Ensure we include the bounding box edges (0,0) and (1,N) if needed\n",
    "    # This ensures the integral covers the full [0,1] range\n",
    "    if points[0][0] > 0:\n",
    "        points = [(0, 0)] + points\n",
    "    if points[-1][0] < 1.0:\n",
    "        points = points + [(1.0, points[-1][1])]\n",
    "\n",
    "    area_step = 0.0\n",
    "    for i in range(len(points) - 1):\n",
    "        x1, y1 = points[i]\n",
    "        x2, _ = points[i+1]\n",
    "        \n",
    "        # Rectangle rule\n",
    "        width = x2 - x1\n",
    "        area_step += width * y1\n",
    "\n",
    "    # Total area of the unit square (1.0 * NUM_DISTRICTS)\n",
    "    total_area = num_districts \n",
    "    area_complement = total_area - area_step\n",
    "    \n",
    "    return {\n",
    "        \"area_step\": area_step,\n",
    "        \"area_complement\": area_complement,\n",
    "        \"area_difference\": abs(area_step - area_complement)\n",
    "    }\n",
